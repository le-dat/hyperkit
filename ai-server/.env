# .env (root level — shared across all services)
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot_pass
POSTGRES_DB=chatbot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# FastAPI Database Connection
CHAT_DATABASE_URL=postgresql+asyncpg://chatbot:chatbot_pass@localhost:5432/chat_db

REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Clerk Authentication
CLERK_FRONTEND_API=your-app.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_...
CLERK_ISSUER_URL=https://your-domain.clerk.accounts.com
CLERK_AUDIENCE=https://your-domain.clerk.accounts.com